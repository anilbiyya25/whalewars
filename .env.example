# Copy this to .env and fill in your values (Supabase → Settings → API).
# On Render, set these as Environment Variables instead of using a file.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Optional:
# CORS_ORIGIN=https://your-domain.com
# BOTS=0
